# ─── DOMAIN ───────────────────────────────────────────────────────────────────
# Your VPS domain (DNS A record must point to this server before deploying)
DOMAIN=pos.yourdomain.com

# ─── DATABASE ──────────────────────────────────────────────────────────────────
DB_NAME=posdb
DB_USER=posuser
DB_PASSWORD=CHANGE_THIS_STRONG_DB_PASSWORD

# ─── REDIS ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=CHANGE_THIS_STRONG_REDIS_PASSWORD

# ─── JWT (generate: openssl rand -base64 64) ───────────────────────────────────
JWT_SECRET=CHANGE_THIS_STRONG_JWT_SECRET_MIN_32_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_STRONG_REFRESH_SECRET_MIN_32_CHARS

# ─── FRONTEND ──────────────────────────────────────────────────────────────────
# Must use /api path prefix (nginx proxies /api → backend:5100)
NEXT_PUBLIC_API_URL=https://pos.yourdomain.com/api
ALLOWED_ORIGINS=https://pos.yourdomain.com

# ─── AI (optional — leave blank to disable AI features) ───────────────────────
OPENAI_API_KEY=

# ─── EXPO / MOBILE (fill with domain for production mobile builds) ─────────────
EXPO_PUBLIC_API_URL=https://pos.yourdomain.com/api
